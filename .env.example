# Copy to .env and set secure local-development values

POSTGRES_DB=nexora_hrms
POSTGRES_USER=nexora_admin
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

PGADMIN_DEFAULT_EMAIL=admin@nexora.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_PGADMIN_PASSWORD

DATABASE_URL=postgresql://nexora_admin:CHANGE_ME_DB_PASSWORD@postgres:5432/nexora_hrms?schema=public
JWT_SECRET=CHANGE_ME_LONG_RANDOM_JWT_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_LONG_RANDOM_REFRESH_SECRET

# Set true only when you intentionally want demo/dev seed data
RUN_DB_SEED=false
CORS_ALLOW_ALL=false
CORS_ORIGINS=http://localhost:3001,http://localhost:3000,http://127.0.0.1:3001

